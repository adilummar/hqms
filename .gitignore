# ─── Dependencies ────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js build output ────────────────────────────────────────────────────
/.next/
/out/
/build

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts
tsc-output.txt

# ─── Environment & secrets ───────────────────────────────────────────────────
# Never commit any .env file — copy .env.example on the server and fill it in
.env
.env.*
!.env.example

# ─── Local-only / scratch / test scripts ─────────────────────────────────────
# These are throw-away dev files and must never reach the server
scratch.ts
scratch.js
test-db.ts
test-db.js
test-query.ts
test-query.js
test-*.ts
test-*.js

# ─── OS & editor artefacts ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
*.pem
.idea/
.vscode/
*.swp
*.swo
*~

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── Coverage & testing ──────────────────────────────────────────────────────
/coverage
.nyc_output

# ─── Deployment platforms ────────────────────────────────────────────────────
.vercel
.netlify

# ─── Drizzle generated (keep migrations, ignore snapshots if desired) ─────────
# Uncomment the line below only if you don't want to commit DB snapshots:
# drizzle/meta/

# ─── Misc ────────────────────────────────────────────────────────────────────
*.zip
*.tar.gz
